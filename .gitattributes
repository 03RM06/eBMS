# Normalize line endings to LF in the repository
* text=auto eol=lf

# Java source files
*.java text eol=lf
*.xml  text eol=lf
*.sql  text eol=lf
*.properties text eol=lf
*.html text eol=lf
*.fxml text eol=lf
*.md   text eol=lf

# PowerShell scripts — keep CRLF on Windows checkout
*.ps1 text eol=crlf

# Binary files
*.p12 binary
*.jks binary
*.jar binary
*.class binary
*.png binary
*.jpg binary
