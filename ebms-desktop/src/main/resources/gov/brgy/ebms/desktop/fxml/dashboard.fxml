<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gov.brgy.ebms.desktop.controller.DashboardController">

  <top>
    <HBox style="-fx-background-color: #1a73e8; -fx-padding: 10;" spacing="10" alignment="CENTER_LEFT">
      <Label text="%app.name" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
    </HBox>
  </top>

  <center>
    <VBox alignment="CENTER" spacing="20" style="-fx-padding: 40;">
      <Label fx:id="welcomeLabel" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
      <Label fx:id="rolesLabel" style="-fx-font-size: 13; -fx-text-fill: #555;"/>
      <Label text="Dashboard content will be implemented in subsequent iterations." style="-fx-text-fill: #777;"/>
    </VBox>
  </center>

  <bottom>
    <Label text="%app.name" style="-fx-padding: 8; -fx-text-fill: #999; -fx-font-size: 11;"/>
  </bottom>
</BorderPane>
