<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gov.brgy.ebms.desktop.controller.HouseholdFormController"
      spacing="12" style="-fx-padding: 20;">

  <Label text="Household Details"
         style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

  <GridPane hgap="12" vgap="10">
    <Label text="House No." GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="houseNoField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="220"/>

    <Label text="Street" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <TextField fx:id="streetField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Purok/Sitio" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextField fx:id="purokField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <Label text="Head Resident ID" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <TextField fx:id="headResidentIdField" GridPane.rowIndex="3" GridPane.columnIndex="1"
               promptText="Leave blank if none"/>
  </GridPane>

  <HBox spacing="10" alignment="CENTER_RIGHT">
    <Button text="%btn.cancel" onAction="#handleCancel"/>
    <Button fx:id="saveButton" text="%btn.save" onAction="#handleSave"
            style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
  </HBox>
</VBox>
