<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gov.brgy.ebms.desktop.controller.ResidentListController"
      spacing="8" style="-fx-padding: 16;">

  <!-- Toolbar -->
  <HBox spacing="8" alignment="CENTER_LEFT">
    <Label text="%nav.residents"
           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <Region HBox.hgrow="ALWAYS"/>
    <TextField fx:id="searchField" promptText="%label.search" prefWidth="200"
               onAction="#onSearch"/>
    <Button text="%label.search" onAction="#onSearch"/>
    <Button text="%btn.create" onAction="#onCreate"
            style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
    <Button text="%btn.delete" onAction="#onDelete"
            style="-fx-text-fill: #c0392b;"/>
  </HBox>

  <!-- Table -->
  <TableView fx:id="table" VBox.vgrow="ALWAYS">
    <columns>
      <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
      <TableColumn fx:id="colCode" text="Code" prefWidth="100"/>
      <TableColumn fx:id="colFirstName" text="First Name" prefWidth="140"/>
      <TableColumn fx:id="colLastName" text="Last Name" prefWidth="140"/>
      <TableColumn fx:id="colSex" text="Sex" prefWidth="70"/>
      <TableColumn fx:id="colStatus" text="Civil Status" prefWidth="100"/>
    </columns>
  </TableView>

  <!-- Pagination -->
  <VBox fx:id="paginationContainer"/>
</VBox>
