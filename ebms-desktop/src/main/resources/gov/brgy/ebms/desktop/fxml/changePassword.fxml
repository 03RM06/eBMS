<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gov.brgy.ebms.desktop.controller.ChangePasswordController"
      alignment="CENTER" spacing="14"
      style="-fx-background-color: #f0f2f5; -fx-padding: 40;">

  <Label text="%changePassword.title"
         style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

  <Label fx:id="titleLabel" text="" wrapText="true" maxWidth="360"
         style="-fx-text-fill: #c0392b;"/>

  <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 8;">
    <GridPane hgap="12" vgap="10">
      <Label text="%changePassword.current" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
      <PasswordField fx:id="currentPasswordField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="220"/>

      <Label text="%changePassword.new" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
      <PasswordField fx:id="newPasswordField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

      <Label text="%changePassword.confirm" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
      <PasswordField fx:id="confirmPasswordField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #c0392b;" wrapText="true" maxWidth="320"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
      <Button fx:id="cancelButton" text="%btn.cancel" onAction="#handleCancel"/>
      <Button fx:id="saveButton" text="%btn.save" onAction="#handleSave"
              style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
    </HBox>
  </VBox>
</VBox>
