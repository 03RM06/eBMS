<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gov.brgy.ebms.desktop.controller.ComplaintFormController"
      spacing="12" style="-fx-padding: 20;">

  <Label text="Complaint"
         style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

  <Label fx:id="statusLabel" text=""/>
  <Label fx:id="caseNumberLabel" text=""/>

  <GridPane hgap="12" vgap="10">
    <Label text="Title *" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="titleField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="300"/>

    <Label text="Complainant Name *" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <TextField fx:id="complainantNameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Respondent Name" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextField fx:id="respondentNameField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
  </GridPane>

  <Label text="Narrative *" style="-fx-font-weight: bold;"/>
  <TextArea fx:id="narrativeArea" prefHeight="120" wrapText="true"/>

  <HBox spacing="10" alignment="CENTER_RIGHT">
    <Button fx:id="cancelButton" text="%btn.cancel" onAction="#handleCancel"/>
    <Button fx:id="saveButton" text="%btn.submit" onAction="#handleSave"
            style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
  </HBox>
</VBox>
