<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gov.brgy.ebms.desktop.controller.MainShellController"
            stylesheets="@../css/app.css">

  <!-- Top bar -->
  <top>
    <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
      <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
      <Label fx:id="lblBarangayName" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: white;"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Label fx:id="lblUser" style="-fx-text-fill: white;"/>
      <ToggleButton fx:id="toggleLang" text="FIL" onAction="#onToggleLang"
                    style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 11;"/>
    </HBox>
  </top>

  <!-- Left sidebar -->
  <left>
    <VBox styleClass="sidebar" prefWidth="190" spacing="2">
      <padding><Insets top="16" right="8" bottom="16" left="8"/></padding>

      <Button fx:id="btnResidents" text="%nav.residents" onAction="#onResidents"
              maxWidth="Infinity" styleClass="nav-btn"/>
      <Button fx:id="btnHouseholds" text="%nav.households" onAction="#onHouseholds"
              maxWidth="Infinity" styleClass="nav-btn"/>
      <Button fx:id="btnClearances" text="%nav.clearances" onAction="#onClearances"
              maxWidth="Infinity" styleClass="nav-btn"/>
      <Button fx:id="btnComplaints" text="%nav.complaints" onAction="#onComplaints"
              maxWidth="Infinity" styleClass="nav-btn"/>
      <Button fx:id="btnFees" text="%nav.fees" onAction="#onFees"
              maxWidth="Infinity" styleClass="nav-btn"/>
      <Button fx:id="btnAudit" text="%nav.audit" onAction="#onAudit"
              maxWidth="Infinity" styleClass="nav-btn"/>

      <Region VBox.vgrow="ALWAYS"/>

      <Button fx:id="btnLogout" text="%nav.logout" onAction="#onLogout"
              maxWidth="Infinity" styleClass="nav-btn"
              style="-fx-text-fill: #e74c3c;"/>
    </VBox>
  </left>

  <!-- Center host -->
  <center>
    <StackPane fx:id="centerHost" style="-fx-background-color: #f5f5f5;"/>
  </center>
</BorderPane>
