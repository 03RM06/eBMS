<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gov.brgy.ebms.desktop.controller.LoginController"
      alignment="CENTER" spacing="16"
      style="-fx-background-color: #f0f2f5; -fx-padding: 40;">

  <Label text="%app.name" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

  <VBox alignment="CENTER" spacing="12"
        style="-fx-background-color: white; -fx-padding: 28; -fx-background-radius: 8;
               -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 2);">

    <Label text="%login.title" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #333;"/>

    <GridPane hgap="12" vgap="10">
      <Label text="%login.username" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
      <TextField fx:id="usernameField" promptText="%login.username"
                 GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="240"/>

      <Label text="%login.password" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
      <PasswordField fx:id="passwordField" promptText="%login.password"
                     GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #c0392b;" wrapText="true" maxWidth="300"/>

    <Button fx:id="loginButton" text="%login.button" onAction="#handleLogin"
            style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-min-width: 240;
                   -fx-font-size: 13; -fx-padding: 8 0 8 0; -fx-background-radius: 4;"/>
  </VBox>
</VBox>
